MM_SERVER=chat.example.com
MM_TEAM=myteam
MM_LOGIN=firehose-bot
MM_PASS=replace-with-password-or-personal-access-token
# Example: MM_PASS=token=your-personal-access-token
# or use a password
# MM_MFA=
# MM_LOGLEVEL=info

# Skip messages sent by the logged-in user (default: true)
# MM_SKIP_OWN=true

# Channel filter: comma-separated regexes matched against "team/channel"
# (or just "channel" for DMs). Whitelist is checked first, then blacklist.
# MM_CHANNEL_WHITELIST=^myteam/general$,^myteam/dev-
# MM_CHANNEL_BLACKLIST=town-square,off-topic

# Sender filter: comma-separated regexes matched against username.
# MM_SENDER_WHITELIST=
# MM_SENDER_BLACKLIST=^bot-,^system$

TG_TOKEN=123456:ABC-your-bot-token
# Negative for groups/channels
# TG_CHAT_ID=-1001234567890
# Positive for account (yourself)
TG_CHAT_ID=1234567890
# Find your chat ID by messaging to @userinfobot on Telegram.
